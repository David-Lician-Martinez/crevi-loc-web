<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="205"
    android:versionName="2.05"
    android:installLocation="auto"
    package="com.komeet.godemarcacion.crevillente"
    platformBuildVersionCode="21"
    platformBuildVersionName="5.0-1521886">
    <uses-sdk
        android:minSdkVersion="8"
        android:targetSdkVersion="21"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <application
        android:theme="@style/AppTheme"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:allowBackup="true">
        <activity
            android:label="@string/app_name"
            android:name="com.komeet.godemarcacion.crevillente.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:label="@string/title_activity_buscar_vivienda"
            android:name="com.komeet.godemarcacion.crevillente.BuscarVivienda"/>
        <activity
            android:label="@string/title_activity_opciones"
            android:name="com.komeet.godemarcacion.crevillente.OpcionesActivity"/>
        <activity
            android:label="@string/title_activity_ayuda"
            android:name="com.komeet.godemarcacion.crevillente.AyudaActivity"/>
    </application>
</manifest>
