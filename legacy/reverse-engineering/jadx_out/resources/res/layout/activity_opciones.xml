<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:background="@drawable/fondoopciones"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/imageView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/titulo"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <CheckBox
        android:textStyle="bold"
        android:textColor="@color/letras_amarillas"
        android:id="@+id/checkbuscaractualizaciones"
        android:background="@drawable/bordecontroles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Buscar actualizaciones al inicio."
        android:layout_below="@+id/imageView2"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textStyle="bold"
        android:textColor="@color/letras_amarillas"
        android:gravity="center_vertical"
        android:id="@+id/textView1"
        android:background="@drawable/bordecontroles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:text="Abrir destino usando la aplicación:"
        android:layout_below="@+id/checkbuscaractualizaciones"
        android:layout_centerHorizontal="true"/>
    <RadioGroup
        android:id="@+id/radioGroup1"
        android:background="@drawable/bordecontroles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textView1"
        android:layout_alignLeft="@+id/textView1">
        <RadioButton
            android:textStyle="bold"
            android:textColor="@color/letras_amarillas"
            android:id="@+id/radiomaps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Google Maps"/>
        <RadioButton
            android:textStyle="bold"
            android:textColor="@color/letras_amarillas"
            android:id="@+id/radiosygic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sygic Navigation"/>
        <RadioButton
            android:textStyle="bold"
            android:textColor="@color/letras_amarillas"
            android:id="@+id/radiotomtom"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TomTom"/>
    </RadioGroup>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <Button
            android:textColor="@color/letras_amarillas"
            android:layout_gravity="center"
            android:id="@+id/button1"
            android:background="@drawable/botones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:layout_weight="1"
            android:onClick="cancelar"/>
        <Button
            android:textColor="@color/letras_amarillas"
            android:layout_gravity="center"
            android:id="@+id/button2"
            android:background="@drawable/botones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Aceptar"
            android:layout_weight="1"
            android:onClick="aceptar"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/opciones"
        android:layout_below="@+id/imageView1"
        android:layout_alignRight="@+id/imageView1"/>
</RelativeLayout>
