<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/updateDialogRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@+id/updateDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualización disponible"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/updateDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:lineSpacingExtra="2dp"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/updateDialogPositiveButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/primary_button_bg"
            android:text="Actualizar ahora"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/updateDialogNegativeButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="No actualizar"
            android:textAllCaps="false"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
