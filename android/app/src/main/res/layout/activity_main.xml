<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="32dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/themeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="10dp"
                android:text="Tema oscuro"
                android:textColor="#4F5A78"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/themeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/panelContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_bg_light"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/titleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:paddingBottom="8dp"
                        android:text="Partidas Crevillente"
                        android:textColor="#1A2240"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/subtitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="18dp"
                        android:text="Busca una partida y abre la ubicación exacta en Maps"
                        android:textColor="#5D6888"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/partidaLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="6dp"
                        android:text="Partida"
                        android:textColor="#253055"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/partidaSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg_light"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/numberLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingBottom="6dp"
                        android:text="Número"
                        android:textColor="#253055"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/numberInput"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg_light"
                        android:hint="Ej. 6"
                        android:inputType="number"
                        android:textColor="#101528"
                        android:textColorHint="#66708A" />

                    <TextView
                        android:id="@+id/suffixLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingBottom="6dp"
                        android:text="Letra (opcional)"
                        android:textColor="#253055"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/suffixInput"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg_light"
                        android:hint="Ej. A"
                        android:textColor="#101528"
                        android:textColorHint="#66708A" />

                    <Button
                        android:id="@+id/searchButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/primary_button_bg"
                        android:text="Buscar"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text=""
                        android:textColor="#A63A52" />

                    <LinearLayout
                        android:id="@+id/resultContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/resultTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#1A2240"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/resultCoords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#4E5B7D" />

                        <Button
                            android:id="@+id/openMapsButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/primary_button_bg"
                            android:text="Abrir en Maps"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/shareButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/secondary_button_bg_light"
                            android:text="Compartir"
                            android:textAllCaps="false"
                            android:textColor="#33406A"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:id="@+id/webLinksDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:background="#C8D2FF" />

                    <include layout="@layout/web_links" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="5dp"
        android:textSize="10sp" />

</FrameLayout>
